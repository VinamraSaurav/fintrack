{
  "name": "@fintrack/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No lint configured yet'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply fintrack-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply fintrack-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fintrack/shared": "workspace:*",
    "@clerk/backend": "^1.20.0",
    "@hono/zod-validator": "^0.4.2",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.4",
    "ulid": "^2.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "wrangler": "^3.109.2"
  }
}
